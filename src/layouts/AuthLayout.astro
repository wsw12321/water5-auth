---
// 🚨 核心魔法：引入 Tailwind 全局样式
import '../styles/global.css';

interface Props {
	title: string;
}
const { title } = Astro.props;
---

<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
	</head>
	<body class="bg-gray-50 text-gray-900 m-0">
		<slot />
	</body>
</html>