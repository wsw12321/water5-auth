---
// 如果 URL 中有错误信息，我们在这里提取
const error = Astro.url.searchParams.get('error');
const redirectTo = Astro.url.searchParams.get('redirect_to') || 'https://main.wsw.wiki';
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>极客通行证 - 登录</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="flex min-h-screen items-center justify-center bg-gray-50 p-4 font-sans">
    <div class="w-full max-w-md bg-white p-8 rounded-xl shadow-lg border border-gray-100">
      <h1 class="text-2xl font-bold mb-6 text-center text-gray-800">极客通行证 (SSO)</h1>
      
      {error && (
        <div class="mb-4 p-3 bg-red-100 text-red-700 rounded-md text-sm font-bold text-center">
          {error}
        </div>
      )}

      <form action={`/api/signin?redirect_to=${encodeURIComponent(redirectTo)}`} method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">邮箱</label>
          <input 
            type="email" 
            name="email"
            class="w-full p-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 outline-none text-gray-800"
            required
          />
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">密码</label>
          <input 
            type="password" 
            name="password"
            class="w-full p-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 outline-none text-gray-800"
            required
          />
        </div>

        <button 
          type="submit" 
          class="w-full bg-blue-600 text-white font-medium py-2 rounded-md hover:bg-blue-700 transition"
        >
          登录
        </button>
      </form>
    </div>
  </body>
</html>