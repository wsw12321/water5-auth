---
import AuthLayout from '../layouts/AuthLayout.astro';
import HomeDashboard from '../components/HomeDashboard';
import { getCurrentAuthUser } from '../lib/supabase';

const user = await getCurrentAuthUser(Astro.cookies, Astro.request);
const email = user?.email || null;
---

<AuthLayout title="控制台 - 水世界通行证">
    <main class="min-h-screen w-full flex items-center justify-center p-4 sm:p-6">
		<HomeDashboard client:load email={email} />
	</main>
</AuthLayout>
